# ---------------------------------------------------------------------------
# staging.tfvars.example
#
# Copy this file to scripts/staging.tfvars and fill in real values.
# DO NOT commit staging.tfvars — it is listed in .gitignore.
# Sensitive values (db_username, db_password) must come from CI/CD secrets
# (TF_VAR_db_username, TF_VAR_db_password) and never be written to disk.
# ---------------------------------------------------------------------------

environment = "staging"

# Provided by the VPC infra feature (separate Terraform feature)
vpc_id     = "vpc-REPLACE_ME"
subnet_ids = ["subnet-REPLACE_ME_1", "subnet-REPLACE_ME_2"]

# Provided by the application security group (ECS infra feature)
app_sg_id = "sg-REPLACE_ME"

# db_username and db_password are intentionally omitted here.
# Supply them via environment variables at plan/apply time:
#   export TF_VAR_db_username="nova_staging_user"
#   export TF_VAR_db_password="$(aws secretsmanager get-secret-value ...)"
#
# api_image is managed by CI/CD — not set in tfvars
