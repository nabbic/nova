{
  "openapi": "3.1.0",
  "info": {
    "title": "Nova API",
    "description": "Nova Technical Due Diligence Platform API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/ping": {
      "get": {
        "tags": [
          "liveness"
        ],
        "summary": "Liveness probe",
        "description": "Returns a pong response with the server's current UTC timestamp. No authentication required.",
        "operationId": "ping_api_ping_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PingResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PingResponse": {
        "type": "object",
        "title": "PingResponse",
        "required": [
          "pong",
          "timestamp"
        ],
        "properties": {
          "pong": {
            "type": "boolean",
            "title": "Pong"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          }
        },
        "example": {
          "pong": true,
          "timestamp": "2025-01-15T14:32:45.123456Z"
        }
      }
    }
  }
}
