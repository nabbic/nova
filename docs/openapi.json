{
  "openapi": "3.1.0",
  "info": {
    "title": "Nova API",
    "description": "Nova Technical Due Diligence Platform API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/version": {
      "get": {
        "summary": "Get API version",
        "operationId": "get_version_api_version_get",
        "responses": {
          "200": {
            "description": "Current API version",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Get Version Api Version Get"
                },
                "example": {
                  "version": "1.0"
                }
              }
            }
          }
        }
      }
    },
    "/api/version-v2": {
      "get": {
        "summary": "Get API version v2",
        "operationId": "get_version_v2_api_version_v2_get",
        "responses": {
          "200": {
            "description": "v2 API version identifier",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Get Version V2 Api Version V2 Get"
                },
                "example": {
                  "version": "2.0"
                }
              }
            }
          }
        }
      }
    },
    "/api/health-info": {
      "get": {
        "summary": "Get factory health info",
        "operationId": "get_health_info_api_health_info_get",
        "responses": {
          "200": {
            "description": "Factory generation and cutover date",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Get Health Info Api Health Info Get"
                },
                "example": {
                  "factory_generation": "v2",
                  "cutover_at": "2026-05-04"
                }
              }
            }
          }
        }
      }
    },
    "/api/engagements": {
      "get": {
        "summary": "List engagements for the calling buyer org",
        "operationId": "list_engagements_api_engagements_get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "Max number of results",
              "default": 20,
              "title": "Limit"
            },
            "description": "Max number of results"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of results to skip",
              "default": 0,
              "title": "Offset"
            },
            "description": "Number of results to skip"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated engagement list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedEngagements"
                },
                "example": {
                  "items": [
                    {
                      "id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                      "name": "Acme Corp Diligence",
                      "status": "active",
                      "created_at": "2026-01-01T00:00:00Z"
                    }
                  ],
                  "total": 1,
                  "limit": 20,
                  "offset": 0
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EngagementResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "status",
          "created_at"
        ],
        "title": "EngagementResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PaginatedEngagements": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/EngagementResponse"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "limit": {
            "type": "integer",
            "title": "Limit"
          },
          "offset": {
            "type": "integer",
            "title": "Offset"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total",
          "limit",
          "offset"
        ],
        "title": "PaginatedEngagements"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
