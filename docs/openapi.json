{
  "openapi": "3.1.0",
  "info": {
    "title": "Nova",
    "description": "Nova multi-tenant SaaS API",
    "version": "0.1.0"
  },
  "paths": {
    "/version": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Get application version metadata",
        "description": "Returns the current application version, build SHA, and deployment environment. All values are sourced from environment variables. No authentication required.",
        "operationId": "get_version_version_get",
        "responses": {
          "200": {
            "description": "Application version metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionResponse"
                },
                "example": {
                  "version": "1.2.3",
                  "build_sha": "abc1234def5678",
                  "environment": "staging"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VersionResponse": {
        "type": "object",
        "title": "VersionResponse",
        "description": "Application version metadata response schema.",
        "required": [
          "version",
          "build_sha",
          "environment"
        ],
        "properties": {
          "version": {
            "type": "string",
            "title": "Version",
            "description": "Application version string, sourced from APP_VERSION env var. Defaults to 'unknown' if not set.",
            "example": "1.2.3"
          },
          "build_sha": {
            "type": "string",
            "title": "Build Sha",
            "description": "Git commit SHA of the current build, sourced from BUILD_SHA env var. Defaults to 'unknown' if not set.",
            "example": "abc1234def5678"
          },
          "environment": {
            "type": "string",
            "title": "Environment",
            "description": "Deployment environment name, sourced from ENVIRONMENT env var. Defaults to 'unknown' if not set.",
            "example": "staging"
          }
        }
      }
    }
  }
}
